// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("HANDLER") // HANDLER | MANAGER | ADMIN | POLICYHOLDER
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedClaims          Claim[]                  @relation("AssignedClaims")
  createdClaims           Claim[]                  @relation("CreatedClaims")
  comments                Comment[]
  auditLogs               AuditLog[]
  policyholderProfile     Policyholder?            @relation("UserPolicyholder")
  notifications           Notification[]           @relation("UserNotifications")
  notificationPreferences NotificationPreference[] @relation("UserNotificationPrefs")
  acprReports             AcprReport[]             @relation("AcprReportAuthor")
  acprConfigs             AcprReportConfig[]       @relation("AcprConfigAuthor")
  gdprRequests            GdprErasureRequest[]     @relation("GdprRequestAuthor")
  gdprExecutions          GdprErasureRequest[]     @relation("GdprExecutor")
  gdprAccessLogs          GdprDataAccessLog[]      @relation("GdprAccessor")
  solvencyProvisions      SolvencyProvision[]      @relation("ProvisionAuthor")
  solvencyReports         SolvencyReport[]         @relation("SolvencyReportAuthor")
}

model Policyholder {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String
  address         String
  // Vehicle info
  vehicleMake     String
  vehicleModel    String
  vehicleYear     Int
  vehiclePlate    String
  vehicleVin      String?
  // Contract info
  policyNumber    String   @unique
  contractStart   DateTime
  contractEnd     DateTime
  coverageType    String   // THIRD_PARTY | COMPREHENSIVE | ALL_RISKS
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String?  @unique
  user            User?    @relation("UserPolicyholder", fields: [userId], references: [id])
  // Geolocation
  latitude        Float?
  longitude       Float?

  claims          Claim[]
  riskScores      RiskScore[]
  riskAlertLogs   RiskAlertLog[]
}

model Claim {
  id              String   @id @default(cuid())
  claimNumber     String   @unique
  status          String   @default("SUBMITTED") // SUBMITTED | UNDER_REVIEW | INFO_REQUESTED | APPROVED | REJECTED | CLOSED
  type            String   // COLLISION | THEFT | VANDALISM | GLASS | FIRE | NATURAL_DISASTER | BODILY_INJURY | OTHER
  description     String
  incidentDate    DateTime
  incidentLocation String
  incidentCity    String?
  incidentZipCode String?
  incidentCountry String?
  latitude        Float?
  longitude       Float?
  thirdPartyInvolved Boolean @default(false)
  thirdPartyInfo  String?  // JSON string
  estimatedAmount Float?
  approvedAmount  Float?
  fraudScore      Int?
  fraudRisk       String?  // LOW | MODERATE | HIGH | CRITICAL
  closureReason   String?
  repairGarage    String?
  expertName      String?
  networkScore    Int?
  networkRisk     String?
  networkId       String?

  policyholderID  String
  policyholder    Policyholder @relation(fields: [policyholderID], references: [id])

  assignedToID    String?
  assignedTo      User?    @relation("AssignedClaims", fields: [assignedToID], references: [id])

  createdByID     String
  createdBy       User     @relation("CreatedClaims", fields: [createdByID], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents          Document[]
  analyses           AIAnalysis[]
  comments           Comment[]
  auditLogs          AuditLog[]
  emailNotifications EmailNotification[]
  notifications      Notification[]      @relation("ClaimNotifications")
  fraudNetwork       FraudNetwork?       @relation("ClaimNetwork", fields: [networkId], references: [id])
  provisions         SolvencyProvision[] @relation("ClaimProvisions")
}

model Document {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  url       String   // file path or storage URL

  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model AIAnalysis {
  id          String   @id @default(cuid())
  type        String   // EXTRACTION | FRAUD_SCORING | ESTIMATION | LETTER_GENERATION
  inputData   String   // JSON string
  outputData  String   // JSON string
  tokensUsed  Int      @default(0)
  durationMs  Int      @default(0)
  model       String   @default("claude-sonnet-4-6")

  claimId     String
  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  isInternal Boolean @default(true)

  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CLAIM_CREATED | CLAIM_UPDATED | STATUS_CHANGED | AI_ANALYSIS_RUN | DOCUMENT_UPLOADED | COMMENT_ADDED | USER_CREATED | USER_UPDATED
  entityType String  // CLAIM | USER | DOCUMENT | COMMENT
  entityId  String
  before    String?  // JSON string of previous state
  after     String?  // JSON string of new state
  metadata  String?  // Additional context JSON

  claimId   String?
  claim     Claim?   @relation(fields: [claimId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model EmailNotification {
  id        String    @id @default(cuid())
  claimId   String
  claim     Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  to        String
  subject   String
  body      String
  sentAt    DateTime?
  error     String?
  createdAt DateTime  @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id])
  type      String    // CLAIM_ASSIGNED | STATUS_CHANGED | FRAUD_ALERT | SLA_BREACH | DOCUMENT_UPLOADED_BY_POLICYHOLDER
  title     String
  body      String
  read      Boolean   @default(false)
  readAt    DateTime?
  claimId   String?
  claim     Claim?    @relation("ClaimNotifications", fields: [claimId], references: [id])
  createdAt DateTime  @default(now())

  @@index([userId, read])
  @@index([claimId])
  @@index([type, claimId])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserNotificationPrefs", fields: [userId], references: [id])
  type         String   // type de notification
  emailEnabled Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, type])
}

model FraudNetwork {
  id            String    @id @default(cuid())
  networkNumber String    @unique
  status        String    @default("ACTIVE") // ACTIVE | SUSPECT | CRITICAL | DISMISSED | UNDER_INVESTIGATION | INACTIVE
  networkScore  Int       @default(0)
  nodeCount     Int       @default(0)
  claimCount    Int       @default(0)
  avgFraudScore Float     @default(0)
  density       Float     @default(0)
  nodesJson     String    @default("[]") // JSON array of node objects
  mergedFrom    String?   // JSON array of merged network IDs
  notes         String?
  version       Int       @default(0)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  links         FraudLink[]
  audits        FraudNetworkAudit[]
  claims        Claim[]   @relation("ClaimNetwork")
}

model FraudLink {
  id           String   @id @default(cuid())
  networkId    String
  sourceType   String   // POLICYHOLDER | GARAGE | EXPERT | LOCATION
  sourceKey    String
  sourceLabel  String
  targetType   String
  targetKey    String
  targetLabel  String
  weight       Float    @default(1.0)
  occurrences  Int      @default(1)
  claimIds     String   @default("[]") // JSON array
  stale        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  network FraudNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([networkId])
  @@index([sourceKey, targetKey])
}

model FraudNetworkAudit {
  id        String   @id @default(cuid())
  networkId String
  action    String   // NETWORK_CREATED | NETWORK_DISMISSED | NETWORK_ESCALATED | NETWORK_RECOMPUTED | NETWORK_ARCHIVED | NETWORK_MERGED
  before    String?  // JSON
  after     String?  // JSON
  metadata  String?  // JSON
  userId    String?
  createdAt DateTime @default(now())

  network FraudNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([networkId])
}

model RiskScore {
  id                    String       @id @default(cuid())
  policyholderId        String
  policyholder          Policyholder @relation(fields: [policyholderId], references: [id], onDelete: Cascade)
  scoreGlobal           Int
  riskLevel             String
  factorHistorique      Float
  factorProfil          Float
  factorZone            Float
  factorPeriode         Float
  factorMeteo           Float
  weatherDataSource     String       @default("FALLBACK_NEUTRAL")
  scoringNotes          String?
  highFrequencyClaimant Boolean      @default(false)
  contractStatus        String
  computedAt            DateTime     @default(now())
  expiresAt             DateTime

  @@index([policyholderId])
  @@index([expiresAt])
  @@index([riskLevel])
}

model WeatherCache {
  id           String   @id @default(cuid())
  latRounded   Float
  lonRounded   Float
  forecastJson String
  meteoScore   Float
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([latRounded, lonRounded])
}

model RiskAlertLog {
  id                  String       @id @default(cuid())
  policyholderId      String
  policyholder        Policyholder @relation(fields: [policyholderId], references: [id], onDelete: Cascade)
  alertType           String
  previousLevel       String
  newLevel            String
  emailSentAt         DateTime?
  emailNotificationId String?
  createdAt           DateTime     @default(now())

  @@index([policyholderId])
}

model AcprReport {
  id                  String   @id @default(cuid())
  reportNumber        String   @unique
  periodStart         DateTime
  periodEnd           DateTime
  generatedAt         DateTime @default(now())
  fileUrl             String?
  fileHash            String?
  status              String   @default("PENDING")
  errorMessage        String?
  claimsOpened        Int      @default(0)
  claimsClosed        Int      @default(0)
  claimsNew           Int      @default(0)
  totalProvisioned    Float    @default(0)
  fraudRate           Float    @default(0)
  avgProcessingDays   Float    @default(0)
  claimToPremiumRatio Float    @default(0)
  indemnitesPaid      Float    @default(0)
  indemnitesWaiting   Float    @default(0)
  configSnapshot      String?
  generatedById       String?
  generatedBy         User?    @relation("AcprReportAuthor", fields: [generatedById], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@index([periodStart, periodEnd])
  @@index([status])
}

model AcprReportConfig {
  id             String   @id @default(cuid())
  key            String   @unique
  logoBase64     String?
  headerTitle    String   @default("Rapport ACPR — ClaimFlow")
  headerSubtitle String?
  sections       String   @default("[\"claims\",\"fraud\",\"sla\",\"provisions\"]")
  footerText     String?
  updatedById    String?
  updatedBy      User?    @relation("AcprConfigAuthor", fields: [updatedById], references: [id])
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model GdprErasureRequest {
  id              String    @id @default(cuid())
  policyholderId  String
  requestedAt     DateTime  @default(now())
  executedAt      DateTime?
  status          String    @default("PENDING")
  rejectionReason String?
  requestedById   String
  requestedBy     User      @relation("GdprRequestAuthor", fields: [requestedById], references: [id])
  executedById    String?
  executedBy      User?     @relation("GdprExecutor", fields: [executedById], references: [id])
  metadata        String?
  @@index([status])
  @@index([policyholderId])
}

model GdprDataAccessLog {
  id          String   @id @default(cuid())
  accessorId  String
  accessor    User     @relation("GdprAccessor", fields: [accessorId], references: [id])
  entityType  String
  entityId    String
  action      String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  @@index([accessorId])
  @@index([entityId, entityType])
  @@index([createdAt])
}

model GdprPurgeLog {
  id           String   @id @default(cuid())
  purgeType    String
  recordsCount Int      @default(0)
  periodCutoff DateTime
  executedAt   DateTime @default(now())
  triggeredBy  String   @default("CRON")
  metadata     String?
  @@index([purgeType])
  @@index([executedAt])
}

model SolvencyProvision {
  id                    String   @id @default(cuid())
  claimId               String
  claim                 Claim    @relation("ClaimProvisions", fields: [claimId], references: [id], onDelete: Cascade)
  computedAt            DateTime @default(now())
  periodQuarter         String
  bestEstimate          Float
  riskFreeRate          Float    @default(0.035)
  scr                   Float
  riskMargin            Float
  totalProvision        Float
  probabilityResolution Float    @default(0.8)
  futureFlows           Float
  status                String   @default("ACTIVE")
  computedById          String?
  computedBy            User?    @relation("ProvisionAuthor", fields: [computedById], references: [id])
  @@index([claimId])
  @@index([periodQuarter])
  @@index([status])
}

model SolvencyReport {
  id              String   @id @default(cuid())
  reportNumber    String   @unique
  periodQuarter   String
  totalBE         Float    @default(0)
  totalSCR        Float    @default(0)
  totalRM         Float    @default(0)
  totalProvisions Float    @default(0)
  claimCount      Int      @default(0)
  generatedAt     DateTime @default(now())
  generatedById   String?
  generatedBy     User?    @relation("SolvencyReportAuthor", fields: [generatedById], references: [id])
  snapshotJson    String?
  @@index([periodQuarter])
}
