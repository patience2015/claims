{
  "mcpServers": {
    "stitch": {
      "command": "npx",
      "args": [
        "-y",
        "stitch-mcp"
      ]
    },
    "github": {
      "command": "node",
      "args": [
        "./.claude/mcp-github.js"
      ]
    }
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/projets/claims/.claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/projets/claims/.claude/hooks/post-edit.sh"
          }
        ]
      }
    ]
  }
}